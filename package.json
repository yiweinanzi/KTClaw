{
    "name": "clawx",
    "version": "0.2.3",
    "pnpm": {
        "onlyBuiltDependencies": [
            "@discordjs/opus",
            "@whiskeysockets/baileys",
            "electron",
            "esbuild",
            "koffi",
            "node-llama-cpp",
            "protobufjs",
            "sharp"
        ],
        "overrides": {
            "isbinaryfile": "^5.0.0"
        }
    },
    "description": "KTClaw - Graphical AI Assistant based on OpenClaw",
    "main": "dist-electron/main/index.js",
    "author": "KTClaw Team",
    "license": "MIT",
    "private": true,
    "scripts": {
        "init": "pnpm install && pnpm run uv:download",
        "dev": "vite",
        "build": "pnpm run package:prepare && electron-builder",
        "build:vite": "vite build",
        "bundle:openclaw": "zx scripts/bundle-openclaw.mjs",
        "bundle:openclaw-plugins": "zx scripts/bundle-openclaw-plugins.mjs",
        "bundle:preinstalled-skills": "zx scripts/bundle-preinstalled-skills.mjs",
        "i18n:check": "node scripts/i18n/check-parity.mjs",
        "lint": "pnpm run lint:check",
        "lint:check": "eslint .",
        "lint:a11y": "eslint src/pages/Activity/index.tsx src/pages/Cron/index.tsx src/pages/Settings/index.tsx src/components/workbench/workbench-empty-state.tsx",
        "lint:fix": "eslint . --fix",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:a11y": "vitest run tests/unit/settings-center.test.tsx tests/unit/workbench-empty-state.test.tsx tests/unit/activity-page.test.tsx tests/unit/cron-page.test.tsx",
        "test:e2e": "playwright test",
        "test:e2e:headed": "playwright test --headed",
        "knip": "knip --config knip.config.ts --include files --no-config-hints",
        "depcruise": "depcruise --config .dependency-cruiser.cjs src electron shared",
        "governance:check": "pnpm run knip && pnpm run depcruise",
        "ralph:codex": "node scripts/ralph/ralph-codex.mjs",
        "comms:replay": "node scripts/comms/replay.mjs",
        "comms:baseline": "node scripts/comms/baseline.mjs",
        "comms:compare": "node scripts/comms/compare.mjs",
        "uv:download": "zx scripts/download-bundled-uv.mjs",
        "uv:download:mac": "zx scripts/download-bundled-uv.mjs --platform=mac",
        "uv:download:win": "zx scripts/download-bundled-uv.mjs --platform=win",
        "uv:download:linux": "zx scripts/download-bundled-uv.mjs --platform=linux",
        "uv:download:all": "zx scripts/download-bundled-uv.mjs --all",
        "icons": "zx scripts/generate-icons.mjs",
        "package:prepare": "pnpm run build:vite && pnpm run bundle:openclaw && pnpm run bundle:openclaw-plugins && pnpm run bundle:preinstalled-skills",
        "package": "pnpm run package:prepare && electron-builder",
        "package:mac": "pnpm run package:prepare && electron-builder --mac",
        "package:win": "pnpm run package:prepare && electron-builder --win",
        "package:linux": "pnpm run package:prepare && electron-builder --linux",
        "package:mac:ci": "pnpm run package:prepare && electron-builder --mac --publish never",
        "package:win:ci": "pnpm run package:prepare && electron-builder --win --publish never",
        "package:linux:ci": "pnpm run package:prepare && electron-builder --linux --publish never",
        "package:linux:smoke": "pnpm run package:prepare && electron-builder --linux dir deb --publish never",
        "smoke:release:linux": "node scripts/smoke/release-smoke.mjs --release-dir=release --linux-unpacked=release/linux-unpacked",
        "smoke:install:linux": "node scripts/smoke/install-smoke-linux.mjs --release-dir=release",
        "smoke:linux": "pnpm run package:linux:smoke && pnpm run smoke:release:linux && pnpm run smoke:install:linux",
        "release": "pnpm run uv:download && pnpm run package:prepare && electron-builder --publish always",
        "version:patch": "pnpm version patch",
        "version:minor": "pnpm version minor",
        "version:major": "pnpm version major",
        "postversion": "git push && git push --tags"
    },
    "dependencies": {
        "clawhub": "^0.5.0",
        "electron-store": "^11.0.2",
        "electron-updater": "^6.8.3",
        "katex": "^0.16.39",
        "ms": "^2.1.3",
        "node-machine-id": "^1.1.12",
        "posthog-node": "^5.28.0",
        "react-syntax-highlighter": "^16.1.1",
        "rehype-katex": "^7.0.1",
        "remark-math": "^6.0.0",
        "ws": "^8.19.0"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@larksuite/openclaw-lark": "2026.3.12",
        "@playwright/test": "^1.58.2",
        "@radix-ui/react-dialog": "^1.1.15",
        "@radix-ui/react-dropdown-menu": "^2.1.16",
        "@radix-ui/react-label": "^2.1.8",
        "@radix-ui/react-progress": "^1.1.8",
        "@radix-ui/react-radio-group": "^1.3.8",
        "@radix-ui/react-select": "^2.2.6",
        "@radix-ui/react-separator": "^1.1.8",
        "@radix-ui/react-slot": "^1.2.4",
        "@radix-ui/react-switch": "^1.2.6",
        "@radix-ui/react-tabs": "^1.1.13",
        "@radix-ui/react-toast": "^1.2.15",
        "@radix-ui/react-tooltip": "^1.2.8",
        "@sliverp/qqbot": "^1.5.4",
        "@soimy/dingtalk": "^3.1.4",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@types/node": "^25.3.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@types/react-syntax-highlighter": "^15.5.13",
        "@types/ws": "^8.18.1",
        "@typescript-eslint/eslint-plugin": "^8.56.0",
        "@typescript-eslint/parser": "^8.56.0",
        "@vitejs/plugin-react": "^5.1.4",
        "@wecom/wecom-openclaw-plugin": "^1.0.6",
        "autoprefixer": "^10.4.24",
        "axe-core": "^4.11.1",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "dependency-cruiser": "^17.3.9",
        "electron": "^40.6.0",
        "electron-builder": "^26.8.1",
        "eslint": "^10.0.0",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-react-refresh": "^0.5.0",
        "framer-motion": "^12.34.2",
        "globals": "^17.3.0",
        "i18next": "^25.8.11",
        "jsdom": "^28.1.0",
        "knip": "^6.0.5",
        "lucide-react": "^0.563.0",
        "openclaw": "2026.3.13",
        "playwright": "^1.58.2",
        "png2icons": "^2.0.1",
        "postcss": "^8.5.6",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "react-i18next": "^16.5.4",
        "react-markdown": "^10.1.0",
        "react-router-dom": "^7.13.0",
        "remark-gfm": "^4.0.1",
        "sharp": "^0.34.5",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.5.0",
        "tailwindcss": "^3.4.19",
        "tailwindcss-animate": "^1.0.7",
        "typescript": "^5.9.3",
        "use-stick-to-bottom": "^1.1.3",
        "vite": "^7.3.1",
        "vite-plugin-electron": "^0.29.0",
        "vite-plugin-electron-renderer": "^0.14.6",
        "vitest": "4.0.18",
        "vitest-axe": "^0.1.0",
        "zustand": "^5.0.11",
        "zx": "^8.8.5"
    },
    "packageManager": "pnpm@10.31.0+sha512.e3927388bfaa8078ceb79b748ffc1e8274e84d75163e67bc22e06c0d3aed43dd153151cbf11d7f8301ff4acb98c68bdc5cadf6989532801ffafe3b3e4a63c268"
}
